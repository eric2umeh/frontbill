# FrontBill Environment Variables
# Copy this file to .env.local and fill in your values

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================

# Your Supabase project URL
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://veuuqawqjvnvmsrukois.supabase.co

# Your Supabase anonymous key (public, safe for client-side)
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (private, for server-side operations only)
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
# IMPORTANT: Do NOT expose this key in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# Database Connection Strings
SUPABASE_URL=postgresql://postgres:password@db.veuuqawqjvnvmsrukois.supabase.co:5432/postgres
POSTGRES_URL=postgresql://postgres:password@db.veuuqawqjvnvmsrukois.supabase.co:5432/postgres
POSTGRES_PRISMA_URL=postgresql://postgres:password@db.veuuqawqjvnvmsrukois.supabase.co:5432/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@db.veuuqawqjvnvmsrukois.supabase.co:5432/postgres

# Database Credentials
POSTGRES_HOST=db.veuuqawqjvnvmsrukois.supabase.co
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# JWT Secret for Supabase
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Node environment (development, production, test)
NODE_ENV=development

# Application URL (used for redirects and OAuth callbacks)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
